<?xml version="1.0" ?>
<robot name="robocop" xmlns:xacro="http://www.ros.org/wiki/xacro" >

<material name="silver">
  <color rgba="0.700 0.700 0.700 1.000"/>
</material>
<material name="green">
  <color rgba="0.0 0.550 0.0 1.000"/>
</material>
<material name="black">
  <color rgba="0.1 0.1 0.1 1.000"/>
</material>
<material name="gray">
  <color rgba="0.5 0.5 0.5 1.000"/>
</material>
</robot>
